{
  "name": "flowforge-server",
  "version": "1.0.0",
  "type": "module",
  "main": "src/server.js",
  "imports": {
    "#config/*": "./src/config/*",
    "#core/*": "./src/core/*",
    "#database/*": "./src/database/*",
    "#engine/*": "./src/engine/*",
    "#modules/*": "./src/modules/*",
    "#routes/*": "./src/routes/*",
    "#app.js": "./src/app.js"
  },
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js"
  },
  "dependencies": {
    "@prisma/client": "^5.14.0",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "prisma": "^5.14.0"
  }
}
